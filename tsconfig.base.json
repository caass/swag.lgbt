{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": false,
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "target": "ESNext"
  },
  "exclude": ["node_modules"]
}
