{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "baseUrl": "./src/",
    "paths": {
      "components/*": ["components/*"],
      "public/*": ["public/*"],
      "styles/*": ["styles/*"],
      "util/*": ["util/*"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx"]
}
