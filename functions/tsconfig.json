{
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "target": "ESNext"
  },
  "include": ["cloudflare.d.ts", "api/**/*.ts"]
}
